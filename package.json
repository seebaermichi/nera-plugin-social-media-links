    "homepage": "https://github.com/seebaermichi/nera-plugin-social-media-links#readme",
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@nera-static/plugin-utils": "^1.2.0"
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "eslint": "^9.31.0",
