        "nera-plugin",
        "static-site-generator",
        "social-media",
        "social-links",
        "fontawesome",
        "icons",
        "jamstack"
    ],
    "author": "Michael Becker",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/seebaermichi/nera-plugin-social-media-links"
    },
    "bugs": {
        "url": "https://github.com/seebaermichi/nera-plugin-social-media-links/issues"
